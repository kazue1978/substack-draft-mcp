# Required for Substack tools that contact a publication.
# Example: yourname.substack.com
SUBSTACK_PUBLICATION_HOST=

# Required only for draft creation/update.
# Use the substack.sid cookie value from your own logged-in Substack session.
# Treat this like a password. Do not paste it into chat.
SUBSTACK_SID=

# Optional. Defaults to https://substack.com for authenticated internal endpoints.
# Must be https://substack.com or a substack.com subdomain.
SUBSTACK_API_ORIGIN=

# Optional. Local folder allowed for upload_image.
# Defaults to ./images from the MCP server working directory.
SUBSTACK_IMAGE_ROOT=

# Optional. Actual image uploads are blocked unless this is set to 1.
# upload_image still validates files in dryRun mode without this.
SUBSTACK_ENABLE_MEDIA_UPLOAD=

# Optional. Internal upload endpoint path. Leave blank unless Substack changes it.
SUBSTACK_IMAGE_UPLOAD_PATH=
